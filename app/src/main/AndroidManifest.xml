<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Location permissions -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- FIX 1: Required on Android 14+ for foreground services with location type -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Storage (for profile pictures) -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- Camera -->
    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:name=".FareGoApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FareGo"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- Splash / Launch screen -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.FareGo.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Onboarding -->
        <activity
            android:name=".activities.OnboardingActivity"
            android:exported="false" />

        <!-- Auth -->
        <activity
            android:name=".activities.AuthActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Main map activity -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize"
            android:windowSoftInputMode="adjustPan" />

        <!-- Profile -->
        <activity
            android:name=".activities.ProfileActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- History -->
        <activity
            android:name=".activities.HistoryActivity"
            android:exported="false" />

        <!-- Trip Detail -->
        <activity
            android:name=".activities.TripDetailActivity"
            android:exported="false" />

        <!-- Google Maps API key -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <!-- FIX 2: Added foregroundServiceType="location" is correct but also
             needs the notification channel ID to exist before startForeground()
             is called — handled by FareGoApp.onCreate() -->
        <service
            android:name=".service.TripNavigationService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <activity
            android:name=".activities.SelectLocationActivity"
            android:exported="false"
            android:label="Select Location"
            android:windowSoftInputMode="adjustResize" />

        <!-- ============================================================
     ALSO ADD to UserProfile.java entity — two new columns for
     home/work location strings. If you are using Room migrations,
     bump your DB version and add a migration. If you use
     fallbackToDestructiveMigration() (which you already do),
     just bump the version number in @Database from 4 to 5.
     ============================================================

     In UserProfile.java add:

     @ColumnInfo(name = "home_location")
     public String homeLocation;

     @ColumnInfo(name = "work_location")
     public String workLocation;

     In AppDatabase.java change:
     version = 4  →  version = 5
-->




        <!-- FIX 3: Remove NotificationReceiver if the class doesn't exist,
             it causes a crash at install time -->
        <!-- DELETED: <receiver android:name=".service.NotificationReceiver" ... /> -->

    </application>

</manifest>