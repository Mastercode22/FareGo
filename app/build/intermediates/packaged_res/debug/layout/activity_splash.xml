<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg_dark">

    <ImageView
        android:id="@+id/iv_splash_logo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_farego_logo"
        android:contentDescription="FareGo Logo"/>

    <TextView
        android:id="@+id/tv_splash_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="FareGo"
        android:textSize="42sp"
        android:textColor="@color/yellow_accent"
        android:layout_marginTop="12dp"/>

    <TextView
        android:id="@+id/tv_splash_tagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Smart Travel. Ghana's Way."
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="8dp"/>

</LinearLayout>