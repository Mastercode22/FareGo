    <string name="onboard_title_3">Choose Your Ride</string>
    <string name="perm_location_rationale">FareGo needs your location to show you on the map and calculate routes.</string>
    <style name="BottomSheetShapeAppearance" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.FareGo.BottomSheet</item>
        <item name="backgroundTint">@color/surface_dark</item>
    </style>
    <style name="BottomSheetStyle" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetShapeAppearance</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>
    <style name="FareGoDialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/yellow_accent</item>
    </style>
    <style name="FareGoDialogTheme" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/FareGoDialogButton</item>
    </style>
    <style name="ShapeAppearance.FareGo.BottomSheet" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
    </style>
    <style name="Theme.FareGo" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/yellow_accent</item>
        <item name="colorPrimaryDark">@color/bg_dark</item>
        <item name="colorAccent">@color/yellow_accent</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="bottomSheetDialogTheme">@style/BottomSheetStyle</item>
    </style>
    <style name="Theme.FareGo.Splash" parent="Theme.FareGo">
        <item name="android:windowFullscreen">false</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
    </style>
    <style name="YellowHintText" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/yellow_accent</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>