    <string name="onboard_desc_1">Live GPS navigation with real-time traffic across Accra, Kumasi, and beyond.</string>
    <string name="onboard_desc_2">Get instant fare estimates for TroTro, Taxi, and Uber — no surprises.</string>
    <string name="onboard_desc_3">Compare transport options, track your trips, and travel smarter every day.</string>
